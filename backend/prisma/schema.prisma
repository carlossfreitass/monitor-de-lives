generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Entity {
  id         Int      @id @default(autoincrement())
  name       String
  slug       String   @unique
  color      String
  logo_url   String   @default("")
  created_at DateTime @default(now())

  gift_map   GiftMap[]
  score      Score?
  events     EventLog[]
}

model Gift {
  id             Int     @id @default(autoincrement())
  tiktok_gift_id Int     @unique
  name           String
  icon_url       String  @default("")
  point_value    Int     @default(1)

  gift_map       GiftMap[]
}

model GiftMap {
  id        Int    @id @default(autoincrement())
  entity_id Int
  gift_id   Int

  entity    Entity @relation(fields: [entity_id], references: [id])
  gift      Gift   @relation(fields: [gift_id],   references: [id])

  @@unique([entity_id, gift_id])
}

model Score {
  id          Int      @id @default(autoincrement())
  entity_id   Int      @unique
  total_score Int      @default(0)
  updated_at  DateTime @updatedAt

  entity      Entity   @relation(fields: [entity_id], references: [id])
}

model EventLog {
  id              Int      @id @default(autoincrement())
  tiktok_gift_id  Int
  gift_name       String
  sender_username String
  repeat_count    Int      @default(1)
  entity_id       Int?
  points_awarded  Int      @default(0)
  raw_event       String
  created_at      DateTime @default(now())

  entity          Entity?  @relation(fields: [entity_id], references: [id])
}