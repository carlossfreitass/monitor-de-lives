generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Entity {
  id         Int      @id @default(autoincrement())
  name       String
  slug       String   @unique
  color      String
  logo_url   String
  created_at DateTime @default(now())

  gift       Gift?
  score      Score?
  events     EventLog[]
}

model Gift {
  id              Int    @id @default(autoincrement())
  tiktok_gift_id  Int    @unique
  name            String
  icon_url        String
  point_value     Int    @default(1)
  entity_id       Int    @unique

  entity          Entity @relation(fields: [entity_id], references: [id])
}

model Score {
  id           Int      @id @default(autoincrement())
  entity_id    Int      @unique
  total_score  Int      @default(0)
  updated_at   DateTime @updatedAt

  entity       Entity   @relation(fields: [entity_id], references: [id])
}

model EventLog {
  id               Int      @id @default(autoincrement())
  tiktok_gift_id   Int
  gift_name        String
  sender_username  String
  repeat_count     Int      @default(1)
  entity_id        Int?
  points_awarded   Int      @default(0)
  raw_event        String
  created_at       DateTime @default(now())

  entity           Entity?  @relation(fields: [entity_id], references: [id])
}